# Demo mode (default): run the entire pipeline client-side with mock data —
# no backend, MongoDB, or OpenAI required. Perfect for screen-recorded demos.
# Set to "false" to call the real Node backend instead.
NEXT_PUBLIC_USE_MOCK=true

# URL of the Ublong Node backend (only used when NEXT_PUBLIC_USE_MOCK=false).
NEXT_PUBLIC_API_URL=http://localhost:3000
